[
  {
    "condition": "remove translation and scale",
    "from": "raw landmarks",
    "invariant": "H @ ones = 0; ||z|| = 1",
    "to": "Helmert preshape"
  },
  {
    "condition": "identify common complex phase",
    "from": "Helmert preshape",
    "invariant": "f(z) = f(exp(i theta) z)",
    "to": "shape [z] in CP^(k-2)"
  },
  {
    "condition": "triangles only: k = 3",
    "from": "shape [z] in CP^(k-2)",
    "invariant": "Hopf coordinates have unit norm",
    "to": "Kendall sphere S^2"
  },
  {
    "condition": "anisotropic axes or unequal tangent variances",
    "from": "shape [z] in CP^(k-2)",
    "invariant": "quadratic form z* A z is phase invariant",
    "to": "complex Bingham"
  },
  {
    "condition": "single modal axis and isotropic transverse scatter",
    "from": "complex Bingham",
    "invariant": "depends on cos^2 Procrustes angle",
    "to": "complex Watson"
  },
  {
    "condition": "scatter matrix and robust weighting are central",
    "from": "shape [z] in CP^(k-2)",
    "invariant": "density unchanged by positive scatter rescaling and phase",
    "to": "complex angular Gaussian"
  },
  {
    "condition": "sample is concentrated near a mean shape",
    "from": "shape [z] in CP^(k-2)",
    "invariant": "log vectors are horizontal to the mean",
    "to": "tangent normal/PCA"
  },
  {
    "condition": "triangle data with sphere diagnostics",
    "from": "Kendall sphere S^2",
    "invariant": "ordinary spherical rotations after Hopf map",
    "to": "spherical Fisher/Watson tests"
  }
]