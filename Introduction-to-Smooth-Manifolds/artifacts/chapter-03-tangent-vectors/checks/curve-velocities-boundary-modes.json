{
  "boundary_model": "H^2 = {(x,y): y >= 0}",
  "checks": {
    "one_sided_endpoint_curves_realize_positive_and_negative_normal_components": true,
    "two_sided_open_interval_requires_zero_normal_velocity": true
  },
  "velocity_modes": [
    {
      "domain": "(-eps, eps)",
      "interpretation": "two-sided tangent to boundary",
      "normal_component": 0.0
    },
    {
      "domain": "[0, eps)",
      "interpretation": "right endpoint curve enters interior",
      "normal_component": 0.82
    },
    {
      "domain": "(-eps, 0]",
      "interpretation": "left endpoint curve enters interior",
      "normal_component": -0.82
    }
  ]
}
